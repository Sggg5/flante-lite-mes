# Copy this file to .env and replace every development placeholder before use.
APP_ENV=development
APP_NAME=福兰特轻量生产计划执行系统
APP_VERSION=0.1.0
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=480
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Local backend default. Relative path is resolved from backend/.
DATABASE_URL=sqlite:///./data/flante_mes.db

# Docker Compose PostgreSQL settings.
POSTGRES_DB=flante_mes
POSTGRES_USER=flante_mes
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Comma-separated browser origins allowed by the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
IMPORT_MAX_FILE_SIZE_MB=20
IMPORT_STORAGE_DIR=./data/imports
